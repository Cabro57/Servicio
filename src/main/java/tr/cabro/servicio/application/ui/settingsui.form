<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="tr.cabro.servicio.application.ui.SettingsUI">
  <grid id="cbd77" binding="main_panel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="10" left="10" bottom="10" right="10"/>
    <constraints>
      <xy x="15" y="25" width="778" height="436"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <tabbedpane id="b6675" binding="tabbed_pane">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <preferred-size width="200" height="200"/>
          </grid>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="15662" binding="main_setting" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <tabbedpane title="Genel Ayarlar"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <nested-form id="67aab" form-file="tr/cabro/servicio/application/panels/SettingsMainPanel.form">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
              </nested-form>
            </children>
          </grid>
          <grid id="77335" binding="device_setting" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <tabbedpane title="Cihaz Ayarları"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <nested-form id="bb69e" form-file="tr/cabro/servicio/application/panels/settingsdevicepanel.form">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
              </nested-form>
            </children>
          </grid>
          <grid id="3845" binding="repair_setting" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <tabbedpane title="Tamir Ayarları"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <nested-form id="665cf" form-file="tr/cabro/servicio/application/panels/settingsrepairpanel.form">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
              </nested-form>
            </children>
          </grid>
          <grid id="3262b" binding="database_setting" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <tabbedpane title="Yedekleme Ayarları"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <nested-form id="a3072" form-file="tr/cabro/servicio/application/panels/SettingsDatabasePanel.form">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
              </nested-form>
            </children>
          </grid>
        </children>
      </tabbedpane>
    </children>
  </grid>
</form>
