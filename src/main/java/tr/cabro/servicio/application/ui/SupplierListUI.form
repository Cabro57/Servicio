      <grid id="c80bb" binding="table_panel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="25" left="5" bottom="5" right="5"/>
