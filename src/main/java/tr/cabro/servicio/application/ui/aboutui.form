        <properties>
          <contentType value="text/html"/>
          <editable value="false"/>
          <text value="&lt;html&gt;&#10;  &lt;head&gt;&#10;    &#10;  &lt;/head&gt;&#10;  &lt;body&gt;&#10;    &lt;h2&gt;&#10;      Servicio (Beta)&#10;    &lt;/h2&gt;&#10;    &lt;p&gt;&#10;      Servicio, teknik servis s&amp;#252;re&amp;#231;lerini daha h&amp;#305;zl&amp;#305;, d&amp;#252;zenli ve takip &#10;      edilebilir hale getirmek i&amp;#231;in geli&amp;#351;tirilen bir y&amp;#246;netim uygulamas&amp;#305;d&amp;#305;r.&#10;    &lt;/p&gt;&#10;    &lt;p&gt;&#10;      Bu beta s&amp;#252;r&amp;#252;m&amp;#252;, par&amp;#231;a y&amp;#246;netimi, m&amp;#252;&amp;#351;teri takibi ve servis s&amp;#252;re&amp;#231;lerini &#10;      kolayla&amp;#351;t&amp;#305;rmaya odaklanarak geli&amp;#351;tirilmi&amp;#351;tir.&#10;    &lt;/p&gt;&#10;    &lt;p style=&quot;margin-top: 10px&quot;&gt;&#10;      &lt;b&gt;Not:&lt;/b&gt;&lt;br&gt;Bu uygulama halen geli&amp;#351;tirme a&amp;#351;amas&amp;#305;ndad&amp;#305;r. G&amp;#246;r&amp;#252;&amp;#351; ve geri &#10;      bildirimlerinizle daha iyi bir Servicio deneyimi olu&amp;#351;turulmas&amp;#305;na katk&amp;#305;da &#10;      bulunabilirsiniz.&#10;    &lt;/p&gt;&#10;  &lt;/body&gt;&#10;&lt;/html&gt;&#10;"/>
        </properties>
      </component>
    </children>
  </grid>
