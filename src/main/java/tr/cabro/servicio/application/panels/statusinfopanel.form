<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="tr.cabro.servicio.application.panels.StatusInfoPanel">
  <grid id="27dc6" binding="main_panel" layout-manager="GridLayoutManager" row-count="2" column-count="6" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="5" left="5" bottom="5" right="5"/>
    <constraints>
      <xy x="20" y="20" width="609" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="ab048" class="javax.swing.JRadioButton" binding="under_repair_radio">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <selected value="true"/>
          <text value="Tamirde"/>
        </properties>
      </component>
      <component id="a49be" class="javax.swing.JRadioButton" binding="ready_radio">
        <constraints>
          <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Hazır"/>
        </properties>
      </component>
      <component id="a1daf" class="javax.swing.JRadioButton" binding="another_service_radio">
        <constraints>
          <grid row="1" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Başka Serviste"/>
        </properties>
      </component>
      <component id="1c423" class="javax.swing.JRadioButton" binding="delivered_radio">
        <constraints>
          <grid row="1" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Teslim Edildi"/>
        </properties>
      </component>
      <component id="69891" class="javax.swing.JRadioButton" binding="return_radio">
        <constraints>
          <grid row="1" column="4" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="İade"/>
        </properties>
      </component>
      <component id="5c536" class="javax.swing.JRadioButton" binding="wait_part_radio">
        <constraints>
          <grid row="1" column="5" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Parça Bekliyor"/>
        </properties>
      </component>
      <component id="72dfb" class="javax.swing.JLabel" binding="title">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="6" vsize-policy="0" hsize-policy="0" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="18" style="1"/>
          <text value="Durum"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
