<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="tr.cabro.servicio.application.panels.CustomerInfoPanel">
  <grid id="27dc6" binding="main_panel" layout-manager="GridLayoutManager" row-count="3" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="5" left="5" bottom="5" right="5"/>
    <constraints>
      <xy x="20" y="20" width="511" height="400"/>
    </constraints>
    <properties/>
    <border type="none">
      <size top="0" left="0" bottom="0" right="0"/>
    </border>
    <children>
      <component id="6173a" class="tr.cabro.servicio.application.compenents.SearchField" binding="customer_field">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="6" anchor="8" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="16"/>
        </properties>
      </component>
      <component id="e15c" class="javax.swing.JButton" binding="new_customer_button">
        <constraints>
          <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="6" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="12" style="1"/>
          <text value="Yeni Müşteri"/>
        </properties>
      </component>
      <grid id="ae135" binding="date_info_panel" layout-manager="GridLayoutManager" row-count="1" column-count="4" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="2" vsize-policy="3" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="67fe6" class="javax.swing.JFormattedTextField" binding="record_date_field">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
          </component>
          <component id="c6897" class="javax.swing.JFormattedTextField" binding="deliver_date_field">
            <constraints>
              <grid row="0" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
          </component>
          <component id="57a69" class="javax.swing.JLabel" binding="record_date_label">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Kayıt Tarihi:"/>
            </properties>
          </component>
          <component id="46f47" class="javax.swing.JLabel" binding="deliver_date_label">
            <constraints>
              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Teslim Tarihi"/>
            </properties>
          </component>
        </children>
      </grid>
      <component id="e835" class="javax.swing.JLabel" binding="title">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="18" style="1"/>
          <text value="Müşteri Bilgileri"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
