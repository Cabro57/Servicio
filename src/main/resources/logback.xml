<configuration>
    <!-- Konsol logu -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Renkli, okunaklı format -->
            <pattern>%cyan(%d{HH:mm:ss}) %highlight([%level]) [%green(%class{0})] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Günlük dosyası logu -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>.servicio/logs/servicio.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>.servicio/logs/log-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%level] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
